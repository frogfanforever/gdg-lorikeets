# Copy this file to .env and fill in your key(s). `.env` is gitignored and is
# auto-sourced by run-task.sh, so exports here reach the WCS eval run.
#
#   cp .env.example .env
#   # then edit .env and paste your key

# Gemini API key for the built-in ai-sdk runner (stages 0-10).
# Get one at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key-here

# --- Optional: local Ollama fixer (stages 9-10). No API key needed. ---
# OLLAMA_BASE_URL=http://localhost:11434/v1
# FIXER_MODEL=gemma4:26b

# --- Optional: custom wiki via the QMD CLI ---
# INDEX_PATH=/absolute/path/to/.qmd/index.sqlite
