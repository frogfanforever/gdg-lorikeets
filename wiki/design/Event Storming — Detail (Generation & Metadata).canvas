		{"id":"extTriz","type":"text","x":560,"y":-700,"width":360,"height":70,"text":"🔌 TRIZ MCP\nsearch_parameter · browse_contradiction_matrix"},
		{"id":"a1","type":"text","color":"2","x":300,"y":-590,"width":250,"height":90,"text":"🟧 Parameters Mapped\n(free text → 39 TRIZ params)"},
