		{"id":"a3","type":"text","color":"2","x":900,"y":-590,"width":240,"height":90,"text":"🟧 Principles Retrieved"},
		{"id":"a4","type":"text","color":"2","x":1200,"y":-590,"width":250,"height":90,"text":"🟧 TRIZ Candidates Emitted\n(1 per principle)"},
