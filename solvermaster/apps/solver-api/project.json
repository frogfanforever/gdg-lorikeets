{
  "name": "solver-api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/solver-api/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "webpack-cli build",
        "args": ["node-env=production"],
        "cwd": "apps/solver-api"
      },
      "configurations": {
        "development": {
          "args": ["node-env=development"]
        }
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "solver-api:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": { "buildTarget": "solver-api:build:development" },
        "production": { "buildTarget": "solver-api:build:production" }
      }
    },
    "test": { "options": { "passWithNoTests": true } }
  }
}
