# Google AI Studio API key (required)
GOOGLE_GENERATIVE_AI_API_KEY=

# TRIZ MCP server (pytriz, Streamable HTTP) — defaults to local workshop server
# Local: MCP_SERVER_URL=http://localhost:8123/mcp
MCP_SERVER_URL=https://triz-mcp-server-66obdg3tha-ew.a.run.app/mcp

# Gemini model used by the agent
AGENT_MODEL=gemini-2.5-flash

# Set to 1 to use @h1deya/langchain-google-genai-ex as a fallback if Gemini
# returns 400 errors on MCP tool schemas
USE_GEMINI_EX=0
