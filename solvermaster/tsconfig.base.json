{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@solvermaster/agent": ["apps/solver-agent/src/index.ts"],
      "@solvermaster/ui": ["libs/ui/src/index.ts"],
      "@solvermaster/data-access": ["libs/data-access/src/index.ts"],
      "@solvermaster/pages/shell": ["libs/pages/shell/src/index.ts"],
      "@solvermaster/pages/problem": ["libs/pages/problem/src/index.ts"],
      "@solvermaster/pages/methods": ["libs/pages/methods/src/index.ts"],
      "@solvermaster/pages/analysis": ["libs/pages/analysis/src/index.ts"],
      "@solvermaster/pages/shortlist": ["libs/pages/shortlist/src/index.ts"],
      "@solvermaster/pages/result": ["libs/pages/result/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
